# PostgreSQL (Railway attaches this to your web service)
DATABASE_URL=postgres://user:password@host:5432/railway

# Optional: restrict Host header (comma-separated), e.g. www.example.com,example.com
# ALLOWED_HOSTS=

# Optional: disable TLS for local Postgres
# PGSSLMODE=disable

# PORT is set by Railway automatically
# PORT=3000

# --- Internal feedback admin (HTTP Basic) ---
# Change these before going live. Defaults are only for local convenience.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# URL path segment for the hidden admin UI (no slashes). Default: internal-sys
# Full URL: https://your-host/<ADMIN_BASE_PATH>/feedback
# ADMIN_BASE_PATH=internal-sys

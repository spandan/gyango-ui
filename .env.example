# Copy to ".env" in the project root — the app loads it automatically (via dotenv).
NODE_ENV=production

# PostgreSQL (Railway: reference this from your Postgres plugin — do not commit real URLs)
DATABASE_URL=postgres://user:password@host:5432/railway

# Optional: restrict Host header (comma-separated), e.g. www.example.com,example.com
# ALLOWED_HOSTS=

# Optional: disable TLS for local Postgres
# PGSSLMODE=disable

# PORT is set by Railway automatically
# PORT=3000

# --- Session cookie signing (required on Railway / any deployed host) ---
# Generate a long random string for stable admin sessions across deploys.
# If omitted on Railway, the app still boots and uses a random secret per process.
SESSION_SECRET=

# Optional: force session cookie Secure flag (default: on when NODE_ENV=production or RAILWAY_PUBLIC_DOMAIN is set)
# Set to 0 only for local HTTP testing behind a proxy.
# SESSION_COOKIE_SECURE=1

# --- Internal feedback admin (session sign-in at /<ADMIN_BASE_PATH>/admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# URL path segment for the admin UI (no slashes). Default: internal-sys
# Inbox URL: https://your-host/<ADMIN_BASE_PATH>/admin
# GET /<ADMIN_BASE_PATH>/feedback redirects to …/admin
# ADMIN_BASE_PATH=internal-sys

# --- Optional: Cloudflare Turnstile on the contact form (set both to enforce) ---
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
